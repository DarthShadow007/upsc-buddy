generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProgress {
  id                 String   @id @default(uuid())
  clerkUserId        String   @unique
  questionsAttempted Int      @default(0)
  accuracy           Float    @default(0.0)
  studyHours         Int      @default(0)
  currentStreak      Int      @default(0)
  longestStreak      Int      @default(0)
  lastStudiedDate    String?
  updatedAt          DateTime @updatedAt
}

model SubjectPerformance {
  id          String @id @default(uuid())
  clerkUserId String
  subjectName String
  accuracy    Float  @default(0.0)
  attemptedQs Int    @default(0)
  @@unique([clerkUserId, subjectName])
}

model Question {
  id            String   @id @default(uuid())
  subject       String
  difficulty    String
  questionType  String   @default("mcq")
  question      String
  options       Json
  correctAnswer Int
  explanation   String
  isAIGenerated Boolean  @default(false)
  createdAt     DateTime @default(now())
  attempts      UserQuestionAttempt[]
  flashcards    Flashcard[]
  mockAnswers   MockTestAnswer[]
}

model UserQuestionAttempt {
  id          String   @id @default(uuid())
  clerkUserId String
  questionId  String
  question    Question @relation(fields: [questionId], references: [id])
  isCorrect   Boolean
  selectedAns Int
  attemptedAt DateTime @default(now())
  @@unique([clerkUserId, questionId])
}

model DailyStudyLog {
  id                 String  @id @default(uuid())
  clerkUserId        String
  date               String
  questionsAttempted Int     @default(0)
  flashcardsReviewed Int     @default(0)
  currentAffairsRead Boolean @default(false)
  mockTestCompleted  Boolean @default(false)
  studyMinutes       Int     @default(0)
  @@unique([clerkUserId, date])
}

model FlashcardDeck {
  id          String      @id @default(uuid())
  clerkUserId String
  title       String
  subjectTag  String
  isAutoGen   Boolean     @default(false)
  cards       Flashcard[]
}

model Flashcard {
  id               String        @id @default(uuid())
  deckId           String
  deck             FlashcardDeck @relation(fields: [deckId], references: [id])
  front            String
  back             String
  easeFactor       Float         @default(2.5)
  interval         Int           @default(1)
  nextReviewAt     DateTime      @default(now())
  lastResult       String?
  sourceQuestionId String?
  sourceQuestion   Question?     @relation(fields: [sourceQuestionId], references: [id])
}

model MockTest {
  id             String           @id @default(uuid())
  clerkUserId    String
  paperType      String           // "GS1" | "CSAT"
  title          String
  score          Float            @default(0)
  totalQuestions Int
  attempted      Int              @default(0)
  timeTaken      Int              @default(0)  // seconds
  incidents      Json             @default("[]")
  completed      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  answers        MockTestAnswer[]
}

model MockTestAnswer {
  id          String    @id @default(uuid())
  mockTestId  String
  mockTest    MockTest  @relation(fields: [mockTestId], references: [id])
  questionId  String
  question    Question  @relation(fields: [questionId], references: [id])
  selectedAns Int?
  isCorrect   Boolean   @default(false)
  timeTaken   Int       @default(0)
  flagged     Boolean   @default(false)
}

model MockTestQuestionUsed {
  id          String @id @default(uuid())
  clerkUserId String
  questionId  String
  mockTestId  String
  usedAt      DateTime @default(now())
  @@unique([clerkUserId, questionId])
}