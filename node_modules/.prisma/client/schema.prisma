generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// This table holds the user's main dashboard stats
model UserProgress {
  id          String @id @default(uuid())
  clerkUserId String @unique // This perfectly links to their secure Google Login!

  // The 4 main dashboard stats
  questionsAttempted Int   @default(0)
  accuracy           Float @default(0.0)
  studyHours         Int   @default(0)
  currentStreak      Int   @default(0)
  longestStreak      Int   @default(0)

  updatedAt DateTime @updatedAt
}

// This table holds the Subject-wise progress bars
model SubjectPerformance {
  id          String @id @default(uuid())
  clerkUserId String
  subjectName String // e.g., "Polity", "History"
  accuracy    Float  @default(0.0)
  attemptedQs Int    @default(0)

  @@unique([clerkUserId, subjectName]) // Ensures one stat row per subject per user
}
